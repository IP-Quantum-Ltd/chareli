# Main API Configuration
ARCADE_API_BASE_URL=https://api.example.com
ARCADE_API_TOKEN=your_service_token_here

# PostgreSQL Database (Game Metadata)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=chareli

# MongoDB Atlas (Vector Hub)
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/chareli_ai?retryWrites=true&w=majority
MONGODB_DB_NAME=chareli_ai

# Redis (Job Queue)
REDIS_URL=redis://localhost:6379

# LLM Providers
OPENAI_API_KEY=sk-...
AI_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=

# Security
WEBHOOK_SECRET=your_webhook_secret_here

# Cron Settings
CRON_INTERVAL_MINUTES=15
