# ArcadeBox main API
ARCADE_API_BASE_URL=https://api.example.com

# Service account (editor role) — dedicated agent identity, not a personal account
SERVICE_EMAIL=ai@agent.com
SERVICE_PASSWORD=<service-account-password>
SERVICE_USER_ID=<service-account-user-id>
ARCADE_API_TOKEN=<non-expiry-editor-role-jwt>

# AI provider - "openai" or "claude"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=         # only needed if AI_PROVIDER=claude
PRIMARY_LLM_MODEL=gpt-4o
SECONDARY_LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini

# Stage 2 data sources
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
MONGODB_URL=
MONGODB_DB_NAME=ai_review_db
MONGODB_RAG_COLLECTION=stage2_grounded_contexts
MONGODB_VECTOR_INDEX=stage2_grounded_context_vector_index
MONGODB_EVALUATION_COLLECTION=agent_evaluations

# ArcadeBox gameplay capture
CLIENT_URL=https://staging.arcadesbox.com/
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800
EXTERNAL_PAGE_TIMEOUT_MS=45000
INTERNAL_PAGE_TIMEOUT_MS=15000

# S3 artifact storage — same credentials as the Node server
# STORAGE_PROVIDER: 's3' (AWS) | 'r2' (Cloudflare R2) | 'local' (dev, no credentials needed)
STORAGE_PROVIDER=s3
AI_AGENT_S3_PREFIX=ai-agent/stage0

# AWS S3 (copy values from Node server .env)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=              # leave empty for real AWS S3
AWS_S3_FORCE_PATH_STYLE=false

# Cloudflare R2 — only needed when STORAGE_PROVIDER=r2
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                # e.g. https://games.yourdomain.com

# Webhook security - set same value in main app as AI_AGENT_WEBHOOK_SECRET
WEBHOOK_SECRET=

# Queue / revision limits
CRON_INTERVAL_MINUTES=15
MAX_PLAN_REVISIONS=2
MAX_DRAFT_REVISIONS=2
JOB_RETENTION_HOURS=24
STAGE0_REQUIRED_CANDIDATES=5
STAGE0_MAX_SEARCH_RESULTS=5
STAGE0_CANDIDATE_CAPTURE_TIMEOUT_SECONDS=30

# Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ArcadeBox-SEO-Agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Optional aliases for langgraph dev / LangSmith tooling
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=ArcadeBox-SEO-Agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
