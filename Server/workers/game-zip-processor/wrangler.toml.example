# Minimal config — infrastructure bindings (KV, R2, vars) are managed by Terraform.
# Queue consumer config stays here because Cloudflare validates the queue handler
# exists in the script before allowing consumer registration.
# The worker name is overridden in CI via: wrangler deploy --name $WORKER_SCRIPT_NAME
# Queue names are templated in CI via sed to match Terraform-provisioned names.

name = "game-zip-processor"
main = "src/index.ts"
compatibility_date = "2024-01-01"

# Cloudflare Account ID
# Get this from: https://dash.cloudflare.com/ (right sidebar)
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

# Queue consumer configuration
# NOTE: Queue names below are placeholders, replaced in CI with actual Terraform-provisioned names.
[[queues.consumers]]
queue = "GAME_ZIP_QUEUE_PLACEHOLDER"
max_batch_size = 1           # Process one ZIP at a time (resource-intensive)
max_batch_timeout = 30       # Wait max 30s for batching
max_retries = 3              # Retry failed jobs 3 times with exponential backoff
dead_letter_queue = "game-zip-dlq"  # Failed jobs go here after 3 retries

# R2 bucket binding
# bucket_name should match your R2 bucket (e.g., from .env: R2_BUCKET)
[[r2_buckets]]
binding = "GAMES_BUCKET"
bucket_name = "YOUR_R2_BUCKET_NAME"

# KV namespace binding for status tracking
# Create KV namespace: wrangler kv:namespace create "GAME_STATUS"
# Copy the ID from the output
[[kv_namespaces]]
binding = "GAME_STATUS"
id = "YOUR_KV_NAMESPACE_ID"

# Environment variables
[vars]
# Development: Using ngrok for local testing
# Production: Use your actual API domain
BACKEND_WEBHOOK_URL = "YOUR_BACKEND_WEBHOOK_URL"

# Secrets (set via: wrangler secret put WEBHOOK_SECRET)
# Run this command to set the secret:
# cd Server/workers/game-zip-processor
# wrangler secret put WEBHOOK_SECRET
# Then paste your secret from .env: CLOUDFLARE_WEBHOOK_SECRET

# Staging environment (optional)
[env.staging]
[env.staging.vars]
BACKEND_WEBHOOK_URL = "https://staging-api.yourdomain.com/api/internal/game-processed"

# Production environment (optional)
[env.production]
[env.production.vars]
BACKEND_WEBHOOK_URL = "https://api.yourdomain.com/api/internal/game-processed"
